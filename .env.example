# archon sponsor wiring — every var optional; unset ⇒ offline stub for that piece.

# NVIDIA local architect brain (Nemotron on vLLM, OpenAI-compatible)
#ARCHON_LOCAL_ENDPOINT=http://localhost:8000/v1/chat/completions
#ARCHON_LOCAL_MODEL=nvidia/Nemotron-Mini-4B-Instruct
#ARCHON_LOCAL_API_KEY=

# Anthropic escalation architect
#ANTHROPIC_API_KEY=

# HiddenLayer Runtime Security (event code AITX-2026)
#HIDDENLAYER_API_KEY=

# OpenShell containment for deploy commands
#ARCHON_SANDBOX=openshell
#ARCHON_SANDBOX_POLICY=policies/deploy.openshell.yaml

# Supabase calibration persistence (table: archon_calibration(env_id, state jsonb))
#SUPABASE_URL=https://YOURPROJECT.supabase.co
#SUPABASE_KEY=
#ARCHON_ENV_ID=default

# JSON fallback state path (used when Supabase unset)
#ARCHON_STATE_PATH=_archon_state/calibration.json
